# GOFR-SEC Development Image
# Extends gofr-base:latest with project-specific dev tools
FROM gofr-base:latest

USER root

RUN apt-get update && apt-get install -y \
    gh \
    openssh-server \
    dnsutils \
    net-tools \
    netcat-openbsd \
    telnet \
    lsof \
    htop \
    strace \
    tcpdump \
    vim \
    jq \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo \"$VERSION_CODENAME\") stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -g 999 docker || true \
    && usermod -aG docker gofr

RUN mkdir -p /home/gofr/devroot/gofr-sec/data \
    && mkdir -p /home/gofr/devroot/gofr-sec/lib \
    && chown -R gofr:gofr /home/gofr/devroot

COPY docker/entrypoint-dev.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /home/gofr/devroot/gofr-sec

RUN mkdir -p /home/gofr/.ssh && chmod 700 /home/gofr/.ssh
RUN uv venv /home/gofr/devroot/gofr-sec/.venv --python=python3.12

EXPOSE 8060 8061 8062

USER gofr
ENTRYPOINT ["/entrypoint.sh"]
CMD ["tail", "-f", "/dev/null"]